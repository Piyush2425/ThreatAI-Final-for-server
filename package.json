{
  "name": "threat-ai",
  "version": "1.0.0",
  "description": "Threat Intelligence Copilot - Production Ready UI",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/js/main.ts --bundle --outfile=static/dist/app.js --sourcemap --watch",
    "build": "esbuild src/js/main.ts --bundle --outfile=static/dist/app.js --minify --legal-comments=none",
    "build:prod": "npm run clean && npm run build && npm run optimize",
    "clean": "del /q static\\dist\\* >nul 2>&1 || true && mkdir static\\dist 2>nul || true",
    "optimize": "node scripts/optimize.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.19.11",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
